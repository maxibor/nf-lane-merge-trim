/*
========================================================================================
    nf-lane_merge_trim Nextflow config
========================================================================================
*/

// Enable DSL2
nextflow.enable.dsl = 2

// Default pipeline parameters
params {
    input    = "fastq.csv"
    outdir   = "results"

    // Boilerplate
    help     = false


    custom_config_version = 'master'
    custom_config_base    = "https://raw.githubusercontent.com/nf-core/configs/${params.custom_config_version}"
}

// Process defaults
process {
    cpus   = 4
    memory = '8.GB'
    time   = '2.h'

    withName: 'FASTP' {
        cpus   = 8
        memory = '16.GB'
        time   = '4.h'
    }
}

// Execution profiles
profiles {
    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
        singularity.enabled    = false
        conda.enabled          = false
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        conda.enabled          = false
    }

    conda {
        conda.enabled          = true
        docker.enabled         = false
        singularity.enabled    = false
    }

    test {
        params.input  = "${projectDir}/tests/fastq.csv"
        params.outdir = "${projectDir}/tests/results"
    }
}

// nf-core institutional configs
includeConfig params.custom_config_base && (!System.getenv('NXF_OFFLINE') || !params.custom_config_base.startsWith('http')) ? "${params.custom_config_base}/nfcore_custom.config" : "/dev/null"

// Capture exit codes from upstream processes when piping
process.shell = ['/bin/bash', '-euo', 'pipefail']

// Manifest
manifest {
    name            = 'nf-lane-merge-trim'
    description     = 'Merge per-lane FASTQ files and perform adapter trimming with fastp'
    version         = '1.0.0'
    nextflowVersion = '!>=23.04.0'
}
